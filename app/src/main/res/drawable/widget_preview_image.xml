<?xml version="1.0" encoding="utf-8"?>
<!--
    今日课程小组件预览图（4x2）
    用于在小组件选择器中显示（兼容 Android 12 以下版本）
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 背景 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- 顶部日期区域 -->
    <item
        android:top="10dp"
        android:left="12dp"
        android:right="12dp"
        android:bottom="70dp">
        <shape android:shape="rectangle">
            <solid android:color="#F5F5F5" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    
    <!-- 课程项模拟 -->
    <item
        android:top="45dp"
        android:left="12dp"
        android:right="12dp"
        android:bottom="15dp">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#F0F0F0" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <!-- 左侧色条 -->
            <item android:width="3dp" android:gravity="left|center_vertical">
                <shape android:shape="rectangle">
                    <solid android:color="#5C6BC0" />
                    <corners android:radius="2dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</layer-list>
