<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 
        网络安全配置
        允许应用访问HTTP（明文）网站，用于兼容使用HTTP协议的教务系统
        注意：教务系统兼容性需要，很多学校仍使用HTTP协议
    -->
    
    <!-- 默认配置：允许明文流量，兼容各类教务系统 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- 信任系统证书 -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Debug配置（仅在调试时启用） -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>















