<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAF8F5"
    android:orientation="vertical"
    android:padding="12.dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2月13日 周五"
            android:textColor="#FF1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFE3F2FD"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="4节"
            android:textColor="#FF1976D2"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="8.dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A000000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="8.dp" />

    <!-- Course 1 - Ongoing -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:padding="8dp">

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:background="#FF5C6BC0" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <TextView
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="08:00"
            android:textColor="#FF1A1A1A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="高等数学"
                android:textColor="#FF1A1A1A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏫 A301"
                android:textColor="#FF666666"
                android:textSize="10sp" />
        </LinearLayout>

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FF5C6BC0"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:text="▶"
            android:textColor="#FFFFFF"
            android:textSize="10sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp" />

    <!-- Course 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:padding="8dp">

        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="#FF66BB6A" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <TextView
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="10:15"
            android:textColor="#FF1A1A1A"
            android:textSize="12sp" />

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="线性代数"
                android:textColor="#FF1A1A1A"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏫 B205"
                android:textColor="#FF666666"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp" />

    <!-- Course 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFF5F5F5"
        android:padding="8dp">

        <View
            android:layout_width="3dp"
            android:layout_height="32dp"
            android:background="#FFFFA726" />

        <View
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <TextView
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="14:30"
            android:textColor="#FF1A1A1A"
            android:textSize="12sp" />

        <View
            android:layout_width="6dp"
            android:layout_height="0dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="大学物理"
                android:textColor="#FF1A1A1A"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏫 C102"
                android:textColor="#FF666666"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
