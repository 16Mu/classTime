<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFAF8F5"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 第10周"
            android:textColor="#FF1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#FFE3F2FD"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="共8节"
            android:textColor="#FF1976D2"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="10.dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1A000000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="10.dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Mon -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFFFF"
            android:gravity="center_horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon"
                android:textColor="#FF1A1A1A"
                android:textSize="11sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FFF5F5F5"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#FF999999"
                android:textSize="10sp" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <!-- Tue -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFFFF"
            android:gravity="center_horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tue"
                android:textColor="#FF1A1A1A"
                android:textSize="11sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FFFFF3E0"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="#FF666666"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <!-- Wed (Today - Highlighted) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFE3F2FD"
            android:gravity="center_horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wed"
                android:textColor="#FF1976D2"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FF1976D2"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="10.sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <!-- Thu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFFFF"
            android:gravity="center_horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thu"
                android:textColor="#FF1A1A1A"
                android:textSize="11sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FFFFF3E0"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="#FF666666"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="0dp" />

        <!-- Fri -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#FFFFFFFF"
            android:gravity="center_horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fri"
                android:textColor="#FF1A1A1A"
                android:textSize="11sp" />

            <View
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="#FFFFF3E0"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="#FF666666"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="8.dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 本周 4 天有课"
        android:textColor="#FF999999"
        android:textSize="10sp" />
</LinearLayout>
