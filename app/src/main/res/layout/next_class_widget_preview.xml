<?xml version="1.0" encoding="utf-8"?>
<!--
    下节课倒计时 Widget 预览布局
    用户在添加 Widget 时看到的预览效果
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- 状态标签行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 即将上课标签 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/widget_status_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="@string/next_class_widget_preview_status"
            android:textColor="@color/widget_status_text"
            android:textSize="11sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 周次 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next_class_widget_preview_week"
            android:textColor="@color/widget_text_tertiary"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- 倒计时 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/next_class_widget_preview_countdown"
            android:textColor="@color/widget_accent"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="4dp"
            android:text="@string/next_class_widget_preview_suffix"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_divider" />

    <View
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- 课程信息 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_preview_course1"
        android:textColor="@color/widget_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/widget_preview_room1"
        android:textColor="@color/widget_text_secondary"
        android:textSize="12sp" />
</LinearLayout>
