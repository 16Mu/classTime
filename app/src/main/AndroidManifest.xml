<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- 通知权限 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- 全屏通知权限 (用于悬浮通知) -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    
    <!-- 震动权限 (用于通知震动) -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- AlarmManager 精确调度权限 -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- 开机启动权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- 唤醒设备权限（用于 AlarmManager） -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- 前台服务权限 (Android 9.0+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- 桌面小组件绑定权限 (Android 12+ 必须，否则 requestPinAppWidget 无效) -->
    <uses-permission android:name="android.permission.REQUEST_BIND_WIDGETS" />
    
    <!-- 文件访问权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".CourseScheduleApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CourseSchedule"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CourseSchedule"
            android:enableOnBackInvokedCallback="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- 悬浮窗更新Activity -->
        <activity
            android:name=".ui.screen.update.FloatingUpdateActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.Dialog"
            android:excludeFromRecents="true"
            android:launchMode="singleTask" />

        
        <!-- ✅ 禁用默认的WorkManager初始化，使用自定义配置 -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- 禁用默认的WorkManager初始化器，改用Configuration.Provider -->
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        
        <!-- FileProvider for sharing files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        
        <!-- 保活前台服务 -->
        <service
            android:name=".service.KeepAliveService"
            android:enabled="true"
            android:exported="false"
            android:stopWithTask="false"
            android:foregroundServiceType="dataSync">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="课程提醒保活服务" />
        </service>
        
        <!-- 后台测试通知接收器 -->
        <receiver
            android:name=".ui.screen.course.BackgroundTestReceiver"
            android:enabled="true"
            android:exported="false">
        </receiver>
        
        <!-- AlarmManager 课程提醒接收器 -->
        <receiver
            android:name=".receiver.AlarmReminderReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.wind.ggbond.classtime.COURSE_REMINDER" />
            </intent-filter>
        </receiver>
        
        <!-- 开机启动接收器 -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>
        
        <!-- 今日课程桌面小组件 -->
        <receiver
            android:name=".widget.TodayCourseWidgetReceiver"
            android:enabled="true"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.wind.ggbond.classtime.ACTION_REFRESH_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/today_course_widget_info" />
        </receiver>

        <!-- 下节课倒计时桌面小组件 -->
        <receiver
            android:name=".widget.NextClassWidgetReceiver"
            android:enabled="true"
            android:exported="true"
            android:label="@string/next_class_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.wind.ggbond.classtime.ACTION_REFRESH_NEXT_CLASS_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/next_class_widget_info" />
        </receiver>

        <!-- 4x4 大尺寸今日课程桌面小组件 (RemoteViews 实现) -->
        <receiver
            android:name=".widget.LargeTodayCourseWidgetProvider"
            android:enabled="true"
            android:exported="true"
            android:label="@string/large_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.wind.ggbond.classtime.ACTION_REFRESH_LARGE_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/large_today_course_widget_info" />
        </receiver>

        <!-- 4x4 大尺寸小组件 ListView 数据服务 -->
        <service
            android:name=".widget.LargeTodayCourseWidgetService"
            android:enabled="true"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <!-- 紧凑列表桌面小组件 -->
        <receiver
            android:name=".widget.CompactListViewWidgetReceiver"
            android:enabled="true"
            android:exported="true"
            android:label="@string/compact_list_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.wind.ggbond.classtime.ACTION_REFRESH_COMPACT_LIST_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/compact_list_widget_info" />
        </receiver>

        <!-- 周概览桌面小组件 -->
        <receiver
            android:name=".widget.WeekOverviewWidgetReceiver"
            android:enabled="true"
            android:exported="true"
            android:label="@string/week_overview_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.wind.ggbond.classtime.ACTION_REFRESH_WEEK_OVERVIEW_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/week_overview_widget_info" />
        </receiver>

        <!-- 智能课表(今日/明日切换)桌面小组件 -->
        <receiver
            android:name=".widget.TomorrowCourseWidgetReceiver"
            android:enabled="true"
            android:exported="true"
            android:label="@string/tomorrow_course_widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.wind.ggbond.classtime.ACTION_REFRESH_TOMORROW_WIDGET" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/tomorrow_course_widget_info" />
        </receiver>

        <!-- 小组件固定回调接收器 -->
        <receiver
            android:name=".widget.WidgetPinCallbackReceiver"
            android:enabled="true"
            android:exported="false" />
    </application>

</manifest>



